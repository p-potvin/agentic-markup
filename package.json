{
  "name": "agentic-markup",
  "version": "0.1.0",
  "description": "Browser extension using a proprietary markup language to customize in-browser agent responses",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.js --bundle --outfile=extension/content.js --format=iife --global-name=AgenticMarkup",
    "build:watch": "esbuild src/index.js --bundle --outfile=extension/content.js --format=iife --global-name=AgenticMarkup --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js extension/**/*.js tests/**/*.js"
  },
  "devDependencies": {
    "esbuild": "^0.20.2",
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
